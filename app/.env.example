# app/.env — read by Next.js dev server (next dev / sst dev).
# Copy to app/.env and fill in the values.
# app/.env is gitignored — never commit it.

# The Cognito hosted UI domain for the shared user pool.
# Find it: AWS Console → Cognito → User Pool → App integration → Domain.
# No https://, no trailing slash.
NEXT_PUBLIC_COGNITO_DOMAIN=ap-feed-manager-auth.auth.us-east-1.amazoncognito.com
